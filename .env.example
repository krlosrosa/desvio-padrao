TELEGRAM_BOT_TOKEN=seu_bot_token
TELEGRAM_CHAT_ID=seu_chat_id
# Valor em R$ que você quer arriscar se o stop for atingido (usado no cálculo da quantidade)
RISCO_FINANCEIRO=1000
PORT=3000
# Host usado pelo Traefik no docker-compose (ex.: notify.seudominio.com)
NOTIFICA_TELEGRAM_HOST=notify.seudominio.com
